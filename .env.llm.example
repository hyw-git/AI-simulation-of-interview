# LLM provider credentials
# Copy this file to .env.llm and fill the secrets.

# OpenAI API key (or other provider key). Set to your real key when ready.
OPENAI_API_KEY=

# Optional overrides
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Speech-to-text options (pick one):
# A) OpenAI Whisper (server-side, supports file upload)
# OPENAI_WHISPER_API_KEY=sk-...
# OPENAI_WHISPER_BASE_URL=https://api.openai.com/v1
# OPENAI_WHISPER_MODEL=whisper-1
#
# B) No API key: use Chrome/Edge "开始语音输入" in interview UI (Web Speech API, browser-side)

# Optional: GitHub personal access token for repo analysis (avoids API rate limits)
GITHUB_TOKEN=

# Optional: proxy for Docker backend to reach api.github.com (common on Windows: 7890 or 10809)
# HTTPS_PROXY=http://host.docker.internal:7890
# HTTP_PROXY=http://host.docker.internal:7890
